@startuml
!theme plain

skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam noteBackgroundColor #F5F5F5
skinparam noteBorderColor #CCCCCC
skinparam arrowColor #333333

title LingFlow 系统架构

package "客户端 (Browser / App)" {
  [WebSocket 连接管理] as client_ws
  [REST API 获取 Token] as client_rest
  [心跳检测 Ping/Pong] as client_heartbeat
}

package "LingFlow 服务层 (Go)" {
  package "connections/wss.go" {
    [连接管理器 (Conn Pool)] as conn_manager
    [心跳引擎 (Ticker)] as heartbeat_engine
    [认证 (HMAC/Debug)\nOrigin 检查 / IP 限制] as auth
  }

  package "services/chat_handler.go" {
    [消息路由分发 (Dispatcher)] as dispatcher
    [流式响应编排 (Streaming)] as streaming
    [#create_skill 处理 (Skill Creator)] as skill_creator
  }

  [services/skill_executor.go\n技能检索 → 上下文注入 → LLM 调用 → 响应格式化] as skill_executor

  package "services/llm.go" {
    [BedrockLLMService\n(Converse API)] as bedrock_llm
    [MockLLMService\n(开发测试用)] as mock_llm
  }

  package "services/s3_skill_loader.go" {
    [ListSkills / LoadSkill] as s3_list
    [UploadSkill / SkillExists] as s3_upload
    [DeleteSkill / StorageURI] as s3_delete
  }

  package "events/ (事件溯源)" {
    [EventStore\n(InMemory)] as event_store
    [Aggregate\n(ChatSession)] as aggregate
    [Command / Handler\n(Event Bus)] as event_bus
  }
}

cloud "AWS Bedrock" {
  [Converse API\n(LLM 推理)] as bedrock
}

cloud "AWS S3" {
  [skills/*.md\n(技能文件存储)] as s3
}

client_ws --> conn_manager : ws:// / wss://
client_rest --> auth : HTTP POST
client_heartbeat --> heartbeat_engine : ping/pong

conn_manager --> dispatcher
heartbeat_engine --> streaming
auth --> dispatcher

dispatcher --> skill_executor
streaming --> skill_executor
skill_creator --> skill_executor

skill_executor --> bedrock_llm
skill_executor --> mock_llm
skill_executor --> s3_list
skill_executor --> s3_upload
skill_executor --> s3_delete

skill_executor --> event_store
skill_executor --> aggregate
skill_executor --> event_bus

bedrock_llm --> bedrock
mock_llm --> bedrock

s3_list --> s3
s3_upload --> s3
s3_delete --> s3

@enduml